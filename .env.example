# Copia a ".env" en la raíz del proyecto (junto a app.py) o define las mismas
# claves en el panel de variables de Railway / tu hosting.
# Nunca subas .env con secretos al repositorio.

# --- CheckID (obligatorio para usar la API) ---
# Clave de la cuenta CheckID. Sin esto: error "Defina la variable de entorno CHECKID_API_KEY."
CHECKID_API_KEY=

# URL base de la API (opcional; por defecto el cliente usa https://www.checkid.mx/api/)
# CHECKID_BASE_URL=https://www.checkid.mx/api

# Timeouts HTTP en segundos (opcionales)
# CHECKID_CONNECT_TIMEOUT=10
# CHECKID_REQUEST_TIMEOUT=45

# Caché en memoria de búsquedas repetidas (segundos; mínimo efectivo 5)
# CHECKID_CACHE_TTL_SECONDS=60

# Límite Flask-Limiter para POST /api/checkid/buscar (sintaxis de limits)
# CHECKID_BUSCAR_RATE_LIMIT=20 per minute

# Almacenamiento del rate limit: memory:// en un solo proceso; en Railway con varias
# réplicas usa Redis u otro backend compartido.
# RATELIMIT_STORAGE_URI=memory://
